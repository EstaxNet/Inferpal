<!--
  PROTOTYPE (visuel uniquement) — Redesign de la section « Serveurs MCP ».
  STATUT : design désormais IMPLÉMENTÉ pour de vrai dans
  Inferpal/ToolWindow/InferpalSettingsContent.xaml (+ InferpalSettingsData.cs)
  pour les 4 listes (MCP, fichiers épinglés, commandes slash, outils). Ce fichier
  reste comme référence de design / mockup autonome.

  Valeurs codées en dur, aucun binding : ouvrir ce fichier dans le concepteur
  XAML de Visual Studio (ou n'importe quel previewer XAML) pour le voir rendu.

  Trois idées démontrées :
    1. En-tête de section riche : chevron + titre + BADGE de compte + bascule
       de VUE segmentée [ Liste | { } JSON ]  (remplace le repli « Avancé (JSON) »
       toujours visible en pied de section).
    2. ÉTAT VIDE explicite qui porte l'explication (absorbe l'icône ⓘ et la
       longue parenthèse du label).
    3. Lignes d'items lisibles : pastille d'état, nom, commande en mono, actions.
-->
<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inferpal — Prototype section MCP"
        Width="430" Height="760"
        Background="#1E1E1E">

    <Window.Resources>
        <!-- Couleurs proches du thème sombre Visual Studio -->
        <SolidColorBrush x:Key="Fg"        Color="#F1F1F1"/>
        <SolidColorBrush x:Key="Subtle"    Color="#9D9D9D"/>
        <SolidColorBrush x:Key="Accent"    Color="#569CD6"/>
        <SolidColorBrush x:Key="RowBg"     Color="#252526"/>
        <SolidColorBrush x:Key="RowBorder" Color="#3F3F46"/>
        <SolidColorBrush x:Key="Primary"   Color="#0E639C"/>
        <SolidColorBrush x:Key="SegOnBg"   Color="#37373D"/>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="16,14">

        <!-- ═══════════════════════════════════════════════════════════════
             EN-TÊTE DE SECTION  (chevron · titre · badge · bascule de vue)
             ═══════════════════════════════════════════════════════════════ -->
        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="▼" Foreground="{StaticResource Accent}"
                       FontSize="9" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="Serveurs MCP" Foreground="{StaticResource Fg}"
                       FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>

            <!-- BADGE de compte : visible d'un coup d'œil, état global de la section -->
            <Border Grid.Column="2" Background="#2D3B2D" CornerRadius="9" Padding="7,1"
                    Margin="8,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="2 actifs / 3" Foreground="#8FD18F" FontSize="10"/>
            </Border>

            <!-- BASCULE de vue segmentée — une seule source de vérité, deux vues -->
            <Border Grid.Column="4" CornerRadius="5" Background="#2D2D30"
                    BorderBrush="{StaticResource RowBorder}" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <Border Background="{StaticResource SegOnBg}" CornerRadius="4" Margin="2" Padding="9,2">
                        <TextBlock Text="Liste" Foreground="{StaticResource Fg}" FontSize="11"/>
                    </Border>
                    <Border Background="Transparent" CornerRadius="4" Margin="2" Padding="9,2">
                        <TextBlock Text="{ } JSON" Foreground="{StaticResource Subtle}" FontSize="11"/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
        <Rectangle Height="1" Fill="#25808080" Margin="0,0,0,10"/>

        <!-- Activation de la section (inchangé, mais désormais le SEUL toggle global) -->
        <CheckBox Content="Activer les serveurs MCP" IsChecked="True"
                  Foreground="{StaticResource Fg}" Margin="0,0,0,12"/>

        <!-- ═══════════════════════════════════════════════════════════════
             VUE « LISTE » — état peuplé
             ═══════════════════════════════════════════════════════════════ -->

        <!-- Ligne 1 : actif -->
        <Border Background="{StaticResource RowBg}" BorderBrush="{StaticResource RowBorder}"
                BorderThickness="1" CornerRadius="4" Padding="8,6" Margin="0,0,0,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Ellipse Grid.Column="0" Width="8" Height="8" Fill="#3FB950"
                         VerticalAlignment="Center" Margin="0,0,9,0"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="github" Foreground="{StaticResource Fg}"
                               FontWeight="SemiBold" FontSize="12"/>
                    <TextBlock Text="npx -y @modelcontextprotocol/server-github"
                               Foreground="{StaticResource Subtle}" FontFamily="Consolas" FontSize="10"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <TextBlock Grid.Column="2" Text="✎" Foreground="{StaticResource Accent}"
                           FontSize="13" VerticalAlignment="Center" Margin="6,0,10,0" Cursor="Hand"/>
                <TextBlock Grid.Column="3" Text="🗑" Foreground="#CC6666"
                           FontSize="13" VerticalAlignment="Center" Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- Ligne 2 : actif -->
        <Border Background="{StaticResource RowBg}" BorderBrush="{StaticResource RowBorder}"
                BorderThickness="1" CornerRadius="4" Padding="8,6" Margin="0,0,0,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Ellipse Grid.Column="0" Width="8" Height="8" Fill="#3FB950"
                         VerticalAlignment="Center" Margin="0,0,9,0"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="filesystem" Foreground="{StaticResource Fg}"
                               FontWeight="SemiBold" FontSize="12"/>
                    <TextBlock Text="npx -y @modelcontextprotocol/server-filesystem C:\dev"
                               Foreground="{StaticResource Subtle}" FontFamily="Consolas" FontSize="10"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <TextBlock Grid.Column="2" Text="✎" Foreground="{StaticResource Accent}"
                           FontSize="13" VerticalAlignment="Center" Margin="6,0,10,0" Cursor="Hand"/>
                <TextBlock Grid.Column="3" Text="🗑" Foreground="#CC6666"
                           FontSize="13" VerticalAlignment="Center" Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- Ligne 3 : désactivé (atténué, pastille grise) -->
        <Border Background="{StaticResource RowBg}" BorderBrush="{StaticResource RowBorder}"
                BorderThickness="1" CornerRadius="4" Padding="8,6" Margin="0,0,0,8" Opacity="0.55">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Ellipse Grid.Column="0" Width="8" Height="8" Fill="#6E6E6E"
                         VerticalAlignment="Center" Margin="0,0,9,0"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="postgres" Foreground="{StaticResource Fg}"
                               FontWeight="SemiBold" FontSize="12"/>
                    <TextBlock Text="désactivé — npx -y @modelcontextprotocol/server-postgres"
                               Foreground="{StaticResource Subtle}" FontFamily="Consolas" FontSize="10"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <TextBlock Grid.Column="2" Text="✎" Foreground="{StaticResource Accent}"
                           FontSize="13" VerticalAlignment="Center" Margin="6,0,10,0"/>
                <TextBlock Grid.Column="3" Text="🗑" Foreground="#CC6666"
                           FontSize="13" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Ajouter -->
        <Border Background="{StaticResource Primary}" CornerRadius="4" Padding="10,5"
                HorizontalAlignment="Left" Margin="0,0,0,22" Cursor="Hand">
            <TextBlock Text="+ Ajouter un serveur" Foreground="White" FontSize="11"/>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             ÉTAT VIDE — montré ici à titre comparatif (ce qui remplace l'écran
             nu de la capture). L'explication vit ici, plus dans une ⓘ.
             ═══════════════════════════════════════════════════════════════ -->
        <TextBlock Text="À quoi ressemble l'état vide :" Foreground="{StaticResource Subtle}"
                   FontStyle="Italic" FontSize="11" Margin="0,0,0,6"/>
        <Border BorderBrush="{StaticResource RowBorder}" BorderThickness="1" CornerRadius="6"
                Background="#211F1F" Padding="18,20" Margin="0,0,0,22">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="🔌" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Aucun serveur MCP configuré"
                           Foreground="{StaticResource Fg}" FontWeight="SemiBold" FontSize="12"
                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock TextWrapping="Wrap" TextAlignment="Center" MaxWidth="300"
                           Foreground="{StaticResource Subtle}" FontSize="11" Margin="0,0,0,12">
                    Les serveurs MCP donnent à l'agent l'accès à des outils externes
                    (fichiers, Git, base de données…). Ajoutez-en un, ou collez une
                    configuration existante via la vue <Run FontFamily="Consolas">{ } JSON</Run>.
                </TextBlock>
                <Border Background="{StaticResource Primary}" CornerRadius="4" Padding="10,5"
                        HorizontalAlignment="Center" Cursor="Hand">
                    <TextBlock Text="+ Ajouter un serveur" Foreground="White" FontSize="11"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             VUE « { } JSON » — même contenu, autre représentation. Ce n'est
             plus un second champ caché « Avancé » : c'est l'autre face de la
             bascule d'en-tête. Plus d'ambiguïté « lequel gagne ».
             ═══════════════════════════════════════════════════════════════ -->
        <TextBlock Text="À quoi ressemble la vue JSON (même section, bascule basculée) :"
                   Foreground="{StaticResource Subtle}" FontStyle="Italic" FontSize="11"
                   Margin="0,0,0,6"/>
        <Border BorderBrush="{StaticResource RowBorder}" BorderThickness="1" CornerRadius="4"
                Background="#1B1B1C" Padding="2">
            <TextBox AcceptsReturn="True" IsReadOnly="True" BorderThickness="0"
                     Background="Transparent" Foreground="#D4D4D4"
                     FontFamily="Consolas" FontSize="11" Padding="8"
                     VerticalScrollBarVisibility="Auto" Height="150"
                     Text='{&#10;  "github": {&#10;    "command": "npx",&#10;    "args": ["-y", "@modelcontextprotocol/server-github"]&#10;  },&#10;  "filesystem": {&#10;    "command": "npx",&#10;    "args": ["-y", "@modelcontextprotocol/server-filesystem", "C:\dev"]&#10;  }&#10;}'/>
        </Border>

    </StackPanel>
    </ScrollViewer>
</Window>
