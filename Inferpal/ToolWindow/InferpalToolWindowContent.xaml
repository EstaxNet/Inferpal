<DataTemplate xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:ext="http://schemas.microsoft.com/visualstudio/extensibility/2022/xaml"
              xmlns:vs="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0">

    <DataTemplate.Resources>
        <BooleanToVisibilityConverter x:Key="b2v" />
        <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Static vs:VsResourceKeys.ComboBoxStyleKey}}" />
    </DataTemplate.Resources>


    <Grid x:Name="root">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- 0: Header -->
            <RowDefinition Height="Auto" />  <!-- 1: Session panel -->
            <RowDefinition Height="*"    />  <!-- 2: Messages list -->
            <RowDefinition Height="Auto" />  <!-- 3: Loading bar -->
            <RowDefinition Height="Auto" />  <!-- 4: Build Failed banner (hidden by default) -->
            <RowDefinition Height="Auto" />  <!-- 5: Input card -->
            <RowDefinition Height="Auto" />  <!-- 6: Hint + token info + context bar -->
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0" BorderThickness="0,0,0,1" BorderBrush="{Binding ThemeBorder}" Padding="8,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"    />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Connection status + active model + mode (left) -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ConnectionStatusText}"
                               Foreground="{Binding ConnectionStatusColor}"
                               FontSize="11" VerticalAlignment="Center" Margin="2,0,6,0"/>
                    <!-- Retry button — only visible when unreachable -->
                    <Button Content="↻"
                            Command="{Binding RetryConnectionCommand}"
                            ToolTip="{Binding TooltipRetryConnection}"
                            Foreground="#F44747"
                            Visibility="{Binding ShowRetryButton, Converter={StaticResource b2v}}"
                            Padding="5,2" Margin="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="4" Background="Transparent" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{Binding DataContext.ThemeHoverBg, ElementName=root}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- VRAM badge — the models currently resident in VRAM; only when loaded -->
                    <TextBlock Foreground="{Binding ThemeSubtleText}"
                               FontSize="10" VerticalAlignment="Center"
                               Margin="2,0,0,0"
                               Visibility="{Binding HasVramStatus, Converter={StaticResource b2v}}"
                               ToolTip="{Binding VramStatus}">
                        <Run Text="VRAM " /><Run Text="{Binding VramStatus}" />
                    </TextBlock>
                </StackPanel>

                <!-- Action buttons (right) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">

                    <!-- Search toggle -->
                    <Button Content="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14" Padding="5,2" Margin="0,0,4,0"
                            Foreground="{Binding ThemeText}"
                            Command="{Binding ToggleSearchCommand}"
                            ToolTip="{Binding TooltipSearchConversation}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="4" Background="Transparent" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{Binding DataContext.ThemeHoverBg, ElementName=root}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Sessions toggle -->
                    <Button Content="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="14" Padding="5,2" Margin="0,0,4,0"
                            Foreground="{Binding ThemeText}"
                            Command="{Binding ToggleSessionPanelCommand}"
                            ToolTip="{Binding TooltipSessionPicker}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="4" Background="Transparent" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{Binding DataContext.ThemeHoverBg, ElementName=root}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Export -->
                    <Button Content="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="14" Padding="5,2" Margin="0,0,4,0"
                            Foreground="{Binding ThemeText}"
                            Command="{Binding ExportCommand}"
                            ToolTip="{Binding TooltipExport}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="4" Background="Transparent" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{Binding DataContext.ThemeHoverBg, ElementName=root}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Clear -->
                    <Button Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14" Padding="5,2"
                            Foreground="{Binding ThemeText}"
                            Command="{Binding ClearCommand}"
                            ToolTip="{Binding TooltipClear}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="4" Background="Transparent" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{Binding DataContext.ThemeHoverBg, ElementName=root}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Search bar (collapsible) ── -->
        <Border Grid.Row="1" Padding="8,5"
                BorderThickness="0,0,0,1" BorderBrush="{Binding ThemeBorder}"
                Visibility="{Binding IsSearchOpen, Converter={StaticResource b2v}}">
            <DockPanel>
                <Button DockPanel.Dock="Right" Padding="6,2" Margin="4,0,0,0"
                        Content="✕" Foreground="{Binding ThemeSubtleText}"
                        ToolTip="{Binding TooltipCloseSearch}"
                        Command="{Binding ClearSearchCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" CornerRadius="4" Background="Transparent"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{Binding DataContext.ThemeHoverBg, ElementName=root}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <TextBox Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         BorderThickness="1" BorderBrush="{Binding ThemeInputBorder}"
                         Background="Transparent" Foreground="{Binding ThemeText}"
                         Padding="8,4" FontSize="12"
                         VerticalContentAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- ── Session Panel (collapsible) ── -->
        <Border Grid.Row="1" Padding="8,6"
                BorderThickness="0,0,0,1" BorderBrush="{Binding ThemeBorder}"
                Background="{Binding ThemeSessionBg}"
                Visibility="{Binding IsSessionPanelOpen, Converter={StaticResource b2v}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"    />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding RecentSessions}"
                          SelectedItem="{Binding SelectedSession, Mode=TwoWay}"
                          ToolTip="{Binding TooltipSessionPicker}"
                          VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="↩"
                        Command="{Binding LoadSessionCommand}"
                        ToolTip="{Binding TooltipLoadSession}"
                        Foreground="{Binding ThemeText}"
                        Margin="6,0,0,0" Padding="8,4" FontSize="11">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" CornerRadius="4" Background="{Binding ThemePanelBg}" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{Binding DataContext.ThemeHoverBg, ElementName=root}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Grid.Column="2" Content="✕"
                        Command="{Binding DeleteSessionCommand}"
                        ToolTip="{Binding TooltipDeleteSession}"
                        Foreground="#CC4444"
                        Margin="4,0,0,0" Padding="8,4" FontSize="11">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" CornerRadius="4" Background="{Binding ThemePanelBg}" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{Binding DataContext.ThemeHoverBg, ElementName=root}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- ── Messages ── -->
        <!-- Tag identifies this list for the in-process ChatAutoScroller class handlers -->
        <ListBox Grid.Row="2"
                 Tag="InferpalChatList"
                 ItemsSource="{Binding Messages}"
                 SelectedItem="{Binding ScrollTarget, Mode=TwoWay}"
                 VirtualizingPanel.IsVirtualizing="False"
                 ScrollViewer.CanContentScroll="False"
                 Background="Transparent" BorderThickness="0"
                 Padding="8,6,8,0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding"          Value="0"/>
                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border x:Name="bubbleRoot" Background="{Binding BubbleBackground}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Margin"       Value="0,2"/>
                                <Setter Property="Padding"      Value="10,7"/>
                                <Setter Property="CornerRadius" Value="6"/>
                                <Style.Triggers>
                                    <!-- Invisible 0-height anchor used for guaranteed scroll-to-bottom -->
                                    <DataTrigger Binding="{Binding Role}" Value="anchor">
                                        <Setter Property="Height"       Value="0"/>
                                        <Setter Property="Margin"       Value="0"/>
                                        <Setter Property="Padding"      Value="0"/>
                                        <Setter Property="CornerRadius" Value="0"/>
                                    </DataTrigger>
                                    <!-- Plan bubble: subtle tinted background, left border accent -->
                                    <DataTrigger Binding="{Binding Role}" Value="plan">
                                        <Setter Property="BorderThickness" Value="3,0,0,0"/>
                                        <Setter Property="BorderBrush"     Value="#569CD6"/>
                                        <Setter Property="Padding"         Value="10,7"/>
                                    </DataTrigger>
                                    <!-- Status bubble: compact live-activity notification, no chrome -->
                                    <DataTrigger Binding="{Binding Role}" Value="status">
                                        <Setter Property="Margin"  Value="0,1"/>
                                        <Setter Property="Padding" Value="10,3"/>
                                    </DataTrigger>
                                    <!-- Search dim: non-matching bubbles fade out when a search is active -->
                                    <DataTrigger Binding="{Binding IsSearchDimmed}" Value="True">
                                        <Setter Property="Opacity" Value="0.2"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <StackPanel>
                            <!-- Header row: toggle (full width), timestamp (centered overlay), copy (right overlay) -->
                            <Grid Margin="0,0,0,3">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Style.Triggers>
                                            <!-- Status bubbles have no header — only the live content text -->
                                            <DataTrigger Binding="{Binding Role}" Value="status">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>

                                <!-- Toggle button fills the entire row; label + chevron left-aligned inside -->
                                <Button Padding="0" BorderThickness="0"
                                        Background="Transparent" FocusVisualStyle="{x:Null}"
                                        HorizontalAlignment="Stretch"
                                        Command="{Binding ToggleExpandCommand}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Cursor" Value="Arrow"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Role}" Value="tool">
                                                    <Setter Property="Cursor" Value="Hand"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <DockPanel LastChildFill="False">
                                                <TextBlock DockPanel.Dock="Left"
                                                           Text="{Binding Label}"
                                                           FontWeight="SemiBold" FontSize="11"
                                                           Foreground="{Binding ThemeSubtleText}"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock DockPanel.Dock="Left"
                                                           FontSize="9" Foreground="{Binding ThemeSubtleText}"
                                                           VerticalAlignment="Center" Margin="4,0,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Setter Property="Text"       Value="▼"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Role}" Value="tool">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                                                    <Setter Property="Text" Value="▶"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DockPanel>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <!-- Timestamp: right-aligned metadata, just left of the copy action -->
                                <TextBlock Text="{Binding Timestamp}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Margin="0,0,26,0"
                                           IsHitTestVisible="False"
                                           FontSize="9" Foreground="{Binding ThemeSubtleText}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Role}" Value="anchor">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Timestamp}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- Copy button: right-aligned overlay -->
                                <Button HorizontalAlignment="Right" Padding="4,1" BorderThickness="0"
                                        Background="Transparent" FocusVisualStyle="{x:Null}"
                                        Command="{Binding CopyCommand}"
                                        ToolTip="{Binding DataContext.TooltipCopy, ElementName=root}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <!-- Overlay action: hidden at rest, fades in only when the bubble is hovered -->
                                            <Setter Property="Opacity" Value="0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMouseOver, ElementName=bubbleRoot}" Value="True">
                                                    <Setter Property="Opacity" Value="1"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsStreaming}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Role}" Value="anchor">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Role}" Value="status">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" CornerRadius="3" Background="Transparent" Padding="{TemplateBinding Padding}">
                                                <TextBlock x:Name="icon"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           Text="&#xE8C8;"
                                                           FontSize="11"
                                                           Foreground="{Binding ThemeSubtleText}"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd"   Property="Background" Value="{Binding DataContext.ThemeHoverBg, ElementName=root}"/>
                                                    <Setter TargetName="icon" Property="Foreground" Value="{Binding DataContext.ThemeText, ElementName=root}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                            </Grid>

                            <!-- Diff viewer: shown for write_file / apply_diff tool bubbles -->
                            <ItemsControl ItemsSource="{Binding DiffLines}"
                                          FontFamily="Consolas, Courier New" FontSize="11"
                                          Margin="0,4,0,2">
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasDiff}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Background="{Binding Background}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="14"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Prefix}"
                                                       Foreground="{Binding Foreground}"
                                                       Padding="2,0" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Text}"
                                                       Foreground="{Binding Foreground}"
                                                       TextWrapping="NoWrap" Padding="2,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Raw content: streaming assistant, tool output, user messages, status -->
                            <TextBlock Text="{Binding Content}" TextWrapping="Wrap"
                                       Foreground="{Binding ThemeText}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Role}" Value="tool">
                                                <Setter Property="FontFamily" Value="Consolas, Courier New" />
                                                <Setter Property="FontSize"   Value="11" />
                                                <Setter Property="Foreground" Value="{Binding ThemeToolText}" />
                                            </DataTrigger>
                                            <!-- Live-status notifications: italic, subtle, compact -->
                                            <DataTrigger Binding="{Binding Role}" Value="status">
                                                <Setter Property="FontStyle"  Value="Italic" />
                                                <Setter Property="FontSize"   Value="11" />
                                                <Setter Property="Foreground" Value="{Binding ThemeSubtleText}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding HasBlocks}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Rendered markdown blocks (assistant messages after streaming) -->
                            <ItemsControl ItemsSource="{Binding Blocks}">
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasBlocks}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <!-- Headings and plain text (no inline formatting) -->
                                            <TextBlock Text="{Binding Text}" TextWrapping="Wrap">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{Binding ThemeText}"/>
                                                        <Setter Property="Margin"     Value="0,1"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Type}" Value="heading1">
                                                                <Setter Property="FontSize"   Value="18"/>
                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                                <Setter Property="Margin"     Value="0,6,0,2"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="heading2">
                                                                <Setter Property="FontSize"   Value="15"/>
                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                                <Setter Property="Margin"     Value="0,5,0,2"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="heading3">
                                                                <Setter Property="FontSize"   Value="13"/>
                                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                                <Setter Property="Margin"     Value="0,4,0,2"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="code_block">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="separator">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                            <!-- Hidden when inline runs are available -->
                                                            <DataTrigger Binding="{Binding HasInlines}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <!-- Inline-formatted runs: paragraph, bullet_item, numbered_item -->
                                            <ItemsControl ItemsSource="{Binding Inlines}">
                                                <ItemsControl.Style>
                                                    <Style TargetType="ItemsControl">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Setter Property="Margin"     Value="0,1"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasInlines}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="bullet_item">
                                                                <Setter Property="Margin" Value="10,1,0,1"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="numbered_item">
                                                                <Setter Property="Margin" Value="10,1,0,1"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ItemsControl.Style>
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Text}"
                                                                   Foreground="{Binding Foreground}"
                                                                   TextWrapping="Wrap">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Margin" Value="0"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsBold}" Value="True">
                                                                            <Setter Property="FontWeight" Value="Bold"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsItalic}" Value="True">
                                                                            <Setter Property="FontStyle" Value="Italic"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsCode}" Value="True">
                                                                            <Setter Property="FontFamily" Value="Consolas, Courier New"/>
                                                                            <Setter Property="FontSize"   Value="11"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Code block: selectable, monospace, dark bg -->
                                            <Border Margin="0,4,0,2" CornerRadius="4">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Type}" Value="code_block">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <TextBox Text="{Binding Text, Mode=OneWay}"
                                                             IsReadOnly="True"
                                                             FontFamily="Consolas, Courier New"
                                                             FontSize="12"
                                                             Foreground="{Binding ThemeCodeText}"
                                                             Background="{Binding ThemeCodeBg}"
                                                             BorderThickness="1" BorderBrush="{Binding ThemeCodeBorder}"
                                                             Padding="10,28,10,8"
                                                             TextWrapping="Wrap"
                                                             VerticalScrollBarVisibility="Disabled"/>
                                                    <!-- Code block action buttons — overlaid top-right -->
                                                    <StackPanel Orientation="Horizontal"
                                                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                                                Margin="0,4,6,0">
                                                        <!-- Save snippet ⭐ -->
                                                        <Button Command="{Binding SaveSnippetCommand}"
                                                                Content="&#xE734;" FontFamily="Segoe MDL2 Assets"
                                                                Margin="0,0,4,0" Padding="5,2" FontSize="11"
                                                                Foreground="{Binding DataContext.ThemeSubtleText, ElementName=root}" Cursor="Hand"
                                                                ToolTip="{Binding DataContext.TooltipSaveSnippet, ElementName=root}">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="bd" CornerRadius="3"
                                                                            Background="{Binding DataContext.ThemePanelBg, ElementName=root}"
                                                                            BorderThickness="1" BorderBrush="{Binding DataContext.ThemeBorder, ElementName=root}"
                                                                            Padding="{TemplateBinding Padding}">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="bd" Property="Background" Value="{Binding DataContext.ThemeHoverBg, ElementName=root}"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                        <!-- Copy -->
                                                        <Button Command="{Binding CopyCodeCommand}"
                                                                Content="Copy"
                                                                Padding="6,2" FontSize="10"
                                                                Foreground="{Binding DataContext.ThemeSubtleText, ElementName=root}" Cursor="Hand">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="bd" CornerRadius="3"
                                                                            Background="{Binding DataContext.ThemePanelBg, ElementName=root}"
                                                                            BorderThickness="1" BorderBrush="{Binding DataContext.ThemeBorder, ElementName=root}"
                                                                            Padding="{TemplateBinding Padding}">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="bd" Property="Background" Value="{Binding DataContext.ThemeHoverBg, ElementName=root}"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <!-- Horizontal rule -->
                                            <Border Height="1" Background="{Binding ThemeCodeBorder}" Margin="0,6">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Type}" Value="separator">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>

                                            <!-- Table row (header and data) -->
                                            <Border BorderThickness="0,0,0,1" BorderBrush="{Binding ThemeTableBorder}">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Setter Property="Margin"     Value="0"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Type}" Value="table_header_row">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Setter Property="Margin"     Value="0,4,0,0"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="table_data_row">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <ItemsControl ItemsSource="{Binding Cells}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <UniformGrid Rows="1"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="{Binding ThemeBg}" Padding="8,5">
                                                                <TextBlock Text="{Binding Text}"
                                                                           Foreground="{Binding ThemeText}"
                                                                           TextWrapping="Wrap">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsHeader}" Value="True">
                                                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Border>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Fix with AI button — visible only on get_diagnostics errors -->
                            <Button Content="{Binding BtnFixWithAi}"
                                    Command="{Binding FixWithAiCommand}"
                                    Margin="0,6,0,0" Padding="10,4" FontSize="11"
                                    HorizontalAlignment="Left">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFixable}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" CornerRadius="4" Background="#7C4DFF" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                              TextElement.Foreground="White" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#9B6DFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Restore All button — visible only on multi-file recap bubbles -->
                            <Button Content="{Binding BtnRestoreAll}"
                                    Command="{Binding RestoreAllCommand}"
                                    Margin="0,6,0,0" Padding="10,4" FontSize="11"
                                    HorizontalAlignment="Left">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRestorable}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" CornerRadius="4" Background="#1B6B35" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                              TextElement.Foreground="White" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#28A047"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Resume button — visible only on the step-mode pause bubble -->
                            <Button Content="{Binding BtnResume}"
                                    Command="{Binding ResumeCommand}"
                                    Margin="0,6,0,0" Padding="10,4" FontSize="11"
                                    HorizontalAlignment="Left">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsResumable}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" CornerRadius="4" Background="#7C4DFF" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                              TextElement.Foreground="White" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#9B6DFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Regenerate button — visible only on the last assistant response -->
                            <Button Content="{Binding BtnRegenerate}"
                                    Command="{Binding RegenerateCommand}"
                                    Margin="0,6,0,0" Padding="10,4" FontSize="11"
                                    HorizontalAlignment="Left">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRegeneratable}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" CornerRadius="4" Background="#7C4DFF" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                              TextElement.Foreground="White" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#9B6DFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- ── Welcome / empty state ── -->
        <!-- Overlays the (empty) message list so the first thing a user sees is what they can do.
             Hidden as soon as the conversation has any real message (Messages.Count > 2). -->
        <Grid Grid.Row="2" Visibility="{Binding ShowWelcome, Converter={StaticResource b2v}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="380" Margin="24">
                <TextBlock Text="◇ Inferpal" HorizontalAlignment="Center"
                           FontSize="20" FontWeight="SemiBold" Foreground="{Binding ThemeText}"/>
                <TextBlock Text="{Binding WelcomeSubtitle}" HorizontalAlignment="Center"
                           FontSize="12" Foreground="{Binding ThemeSubtleText}"
                           Margin="0,4,0,18" TextWrapping="Wrap" TextAlignment="Center"/>

                <UniformGrid Columns="2">
                    <!-- Each card drops a slash command into the prompt and sends it (one-click entry) -->
                    <Button Command="{Binding RunSuggestionCommand}" CommandParameter="/explain"
                            Margin="4" Padding="0" BorderThickness="0" Background="Transparent"
                            Cursor="Hand" HorizontalContentAlignment="Stretch">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="8" Padding="12,10"
                                        Background="{Binding ThemeInputBg}"
                                        BorderThickness="1" BorderBrush="{Binding ThemeInputBorder}">
                                    <StackPanel>
                                        <TextBlock Text="⚡" FontSize="16"/>
                                        <TextBlock Text="{Binding WelcomeCardExplain}" Foreground="{Binding ThemeText}"
                                                   FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <!-- Accent border on hover only — theme-safe (no dark bg flash in light theme) -->
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="BorderBrush" Value="#7C4DFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Command="{Binding RunSuggestionCommand}" CommandParameter="/fix"
                            Margin="4" Padding="0" BorderThickness="0" Background="Transparent"
                            Cursor="Hand" HorizontalContentAlignment="Stretch">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="8" Padding="12,10"
                                        Background="{Binding ThemeInputBg}"
                                        BorderThickness="1" BorderBrush="{Binding ThemeInputBorder}">
                                    <StackPanel>
                                        <TextBlock Text="🐛" FontSize="16"/>
                                        <TextBlock Text="{Binding WelcomeCardFix}" Foreground="{Binding ThemeText}"
                                                   FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <!-- Accent border on hover only — theme-safe (no dark bg flash in light theme) -->
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="BorderBrush" Value="#7C4DFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Command="{Binding RunSuggestionCommand}" CommandParameter="/test"
                            Margin="4" Padding="0" BorderThickness="0" Background="Transparent"
                            Cursor="Hand" HorizontalContentAlignment="Stretch">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="8" Padding="12,10"
                                        Background="{Binding ThemeInputBg}"
                                        BorderThickness="1" BorderBrush="{Binding ThemeInputBorder}">
                                    <StackPanel>
                                        <TextBlock Text="🧪" FontSize="16"/>
                                        <TextBlock Text="{Binding WelcomeCardTest}" Foreground="{Binding ThemeText}"
                                                   FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <!-- Accent border on hover only — theme-safe (no dark bg flash in light theme) -->
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="BorderBrush" Value="#7C4DFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Command="{Binding RunSuggestionCommand}" CommandParameter="/help"
                            Margin="4" Padding="0" BorderThickness="0" Background="Transparent"
                            Cursor="Hand" HorizontalContentAlignment="Stretch">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="8" Padding="12,10"
                                        Background="{Binding ThemeInputBg}"
                                        BorderThickness="1" BorderBrush="{Binding ThemeInputBorder}">
                                    <StackPanel>
                                        <TextBlock Text="❓" FontSize="16"/>
                                        <TextBlock Text="{Binding WelcomeCardHelp}" Foreground="{Binding ThemeText}"
                                                   FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <!-- Accent border on hover only — theme-safe (no dark bg flash in light theme) -->
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="BorderBrush" Value="#7C4DFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </UniformGrid>

                <!-- Active model · mode, where there's room to show it in full -->
                <TextBlock HorizontalAlignment="Center" Margin="0,16,0,0"
                           FontSize="11" Foreground="{Binding ThemeSubtleText}"
                           TextTrimming="CharacterEllipsis">
                    <Run Text="{Binding ActiveModelLabel}" /><Run Text="   ·   " /><Run Text="{Binding AgentModeLabel}" />
                </TextBlock>
            </StackPanel>
        </Grid>

        <!-- ── Loading ── -->
        <!-- The old status label + Cancel button were removed: progress is now shown on the
             tool/plan bubbles, and Cancel folded into the send button (becomes a Stop button
             while IsLoading). Row 3 stays empty (Auto height collapses to 0). -->

        <!-- ── Build Failed banner ── -->
        <!-- Shown when VS finishes a build with errors (LocalPilot-style red banner).    -->
        <!-- Positioned between the loading bar and the input card, hidden by default.    -->
        <Border Grid.Row="4" Margin="8,6,8,0" CornerRadius="8"
                Background="#5C1A1A" BorderThickness="1" BorderBrush="#8B2020"
                Visibility="{Binding HasBuildFailedBanner, Converter={StaticResource b2v}}">
            <Grid Margin="12,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"    />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Left: icon + title + first error line -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⊘ " Foreground="#FF7070" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding BuildBannerTitle}" Foreground="#FF7070" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{Binding BuildFailedFirstError}"
                               Foreground="#FFAAAA" FontSize="10"
                               FontFamily="Consolas, Courier New"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,3,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding BuildFailedFirstError}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- Right: Dismiss + Fix with AI -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- Dismiss -->
                    <Button Margin="0,0,6,0" Padding="10,4" FontSize="11"
                            Command="{Binding DismissBuildBannerCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="4" Background="#2D2D30"
                                        Padding="{TemplateBinding Padding}">
                                    <TextBlock Text="{Binding BuildBannerDismiss}" Foreground="#CCCCCC"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#444"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Fix with AI -->
                    <Button Padding="10,4" FontSize="11"
                            Command="{Binding FixBuildBannerCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="4" Background="#7C4DFF"
                                        Padding="{TemplateBinding Padding}">
                                    <TextBlock Text="{Binding BuildBannerFix}" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#9B5DFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Input card ── -->
        <Border Grid.Row="5" Margin="8,4,8,0" CornerRadius="8"
                BorderThickness="1" BorderBrush="{Binding ThemeInputBorder}" Background="{Binding ThemeInputBg}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*"    />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Suggestion popups (row 0) — slash commands OR @mention, mutually exclusive -->
                <StackPanel Grid.Row="0">

                    <!-- /slash suggestions — visible only while typing /cmd (no space yet) -->
                    <Border BorderThickness="0,0,0,1" BorderBrush="{Binding ThemeBorder}"
                            Visibility="{Binding HasSlashSuggestions, Converter={StaticResource b2v}}">
                        <ListBox ItemsSource="{Binding SlashSuggestions}"
                                 MaxHeight="210"
                                 Background="Transparent" BorderThickness="0"
                                 VirtualizingPanel.IsVirtualizing="False"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding"                    Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="FocusVisualStyle"           Value="{x:Null}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding SelectCommand}"
                                            HorizontalContentAlignment="Stretch"
                                            Padding="0" FocusVisualStyle="{x:Null}"
                                            BorderThickness="0" Background="Transparent">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Padding="12,5" Background="Transparent">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding Command}"
                                                                   FontSize="12" FontWeight="SemiBold"
                                                                   FontFamily="Consolas,Courier New,monospace"
                                                                   Foreground="{Binding ThemeText}"
                                                                   MinWidth="110"/>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Description}"
                                                                   FontSize="11"
                                                                   Foreground="{Binding ThemeSubText}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="{Binding DataContext.ThemeHoverBg, ElementName=root}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <!-- @mention suggestions — visible only while typing @xxx -->
                    <Border BorderThickness="0,0,0,1" BorderBrush="{Binding ThemeBorder}"
                            Visibility="{Binding HasMentionSuggestions, Converter={StaticResource b2v}}">
                        <ListBox ItemsSource="{Binding MentionSuggestions}"
                                 MaxHeight="180"
                                 Background="Transparent" BorderThickness="0"
                                 VirtualizingPanel.IsVirtualizing="False"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding"                  Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="FocusVisualStyle"         Value="{x:Null}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding SelectCommand}"
                                            HorizontalContentAlignment="Stretch"
                                            Padding="0" FocusVisualStyle="{x:Null}"
                                            BorderThickness="0" Background="Transparent">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Padding="12,5" Background="Transparent">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Label}"
                                                                   FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="{Binding ThemeText}"/>
                                                        <TextBlock Text="{Binding SubLabel}"
                                                                   FontSize="10"
                                                                   Foreground="{Binding ThemeSubText}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="{Binding DataContext.ThemeHoverBg, ElementName=root}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <!-- ＋ Add-context menu — one labelled list replacing the old row of attach glyphs.
                         Each row runs its existing command; the handlers close the menu (IsAttachMenuOpen=false). -->
                    <Border BorderThickness="0,0,0,1" BorderBrush="{Binding ThemeBorder}"
                            Visibility="{Binding IsAttachMenuOpen, Converter={StaticResource b2v}}">
                        <StackPanel>
                            <Button Command="{Binding AttachFileCommand}"
                                    HorizontalContentAlignment="Stretch" Padding="0"
                                    FocusVisualStyle="{x:Null}" BorderThickness="0" Background="Transparent">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Padding="12,6" Background="Transparent">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="22"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" FontFamily="Segoe MDL2 Assets" Text="&#xE8A5;"
                                                           FontSize="13" Foreground="{Binding ThemeSubtleText}" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding MenuAttachFile}" FontSize="12" FontWeight="SemiBold"
                                                               Foreground="{Binding ThemeText}"/>
                                                    <TextBlock Text="{Binding TooltipAttachFile}" FontSize="10"
                                                               Foreground="{Binding ThemeSubtleText}" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="{Binding DataContext.ThemeHoverBg, ElementName=root}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button Command="{Binding AttachSelectionCommand}"
                                    HorizontalContentAlignment="Stretch" Padding="0"
                                    FocusVisualStyle="{x:Null}" BorderThickness="0" Background="Transparent">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Padding="12,6" Background="Transparent">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="22"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" FontFamily="Segoe MDL2 Assets" Text="&#xE71D;"
                                                           FontSize="13" Foreground="{Binding ThemeSubtleText}" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding MenuAttachSelection}" FontSize="12" FontWeight="SemiBold"
                                                               Foreground="{Binding ThemeText}"/>
                                                    <TextBlock Text="{Binding TooltipAttachSelection}" FontSize="10"
                                                               Foreground="{Binding ThemeSubtleText}" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="{Binding DataContext.ThemeHoverBg, ElementName=root}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button Command="{Binding BrowseFileCommand}"
                                    HorizontalContentAlignment="Stretch" Padding="0"
                                    FocusVisualStyle="{x:Null}" BorderThickness="0" Background="Transparent">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Padding="12,6" Background="Transparent">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="22"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" FontFamily="Segoe MDL2 Assets" Text="&#xE898;"
                                                           FontSize="13" Foreground="{Binding ThemeSubtleText}" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding MenuBrowseFile}" FontSize="12" FontWeight="SemiBold"
                                                               Foreground="{Binding ThemeText}"/>
                                                    <TextBlock Text="{Binding TooltipBrowseFile}" FontSize="10"
                                                               Foreground="{Binding ThemeSubtleText}" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="{Binding DataContext.ThemeHoverBg, ElementName=root}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button Command="{Binding PinFileCommand}"
                                    HorizontalContentAlignment="Stretch" Padding="0"
                                    FocusVisualStyle="{x:Null}" BorderThickness="0" Background="Transparent">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Padding="12,6" Background="Transparent">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="22"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" FontFamily="Segoe MDL2 Assets" Text="&#xE718;" FontSize="13"
                                                           Foreground="{Binding ThemeSubtleText}" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding MenuPinFile}" FontSize="12" FontWeight="SemiBold"
                                                               Foreground="{Binding ThemeText}"/>
                                                    <TextBlock Text="{Binding TooltipPinFile}" FontSize="10"
                                                               Foreground="{Binding ThemeSubtleText}" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="{Binding DataContext.ThemeHoverBg, ElementName=root}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- Pinned + attachment chip strips (row 1) -->
                <StackPanel Grid.Row="1">

                    <!-- Pinned context files strip (📌, gold) — persistent, survives sends.
                         Always injected into the system prompt; managed here instead of Settings. -->
                    <ItemsControl ItemsSource="{Binding PinnedFiles}" Margin="8,6,8,0">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasPinnedFiles}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,4,4" CornerRadius="4" BorderThickness="1"
                                        Background="{Binding Background}" BorderBrush="{Binding BorderColor}">
                                    <DockPanel Margin="6,3" LastChildFill="True">
                                        <!-- × unpin button -->
                                        <Button DockPanel.Dock="Right" Margin="4,0,0,0"
                                                Foreground="{Binding Foreground}"
                                                FocusVisualStyle="{x:Null}"
                                                Command="{Binding RemoveCommand}" Padding="2,0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="bd" Background="Transparent"
                                                            Padding="{TemplateBinding Padding}">
                                                        <TextBlock Text="×" FontSize="12"
                                                                   Foreground="{TemplateBinding Foreground}"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bd" Property="Background" Value="#40FFFFFF"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <!-- pinned label -->
                                        <TextBlock FontSize="10" VerticalAlignment="Center"
                                                   Foreground="{Binding Foreground}"
                                                   MaxWidth="160" TextTrimming="CharacterEllipsis">
                                            <Run FontFamily="Segoe MDL2 Assets" Text="&#xE718;  "/><Run Text="{Binding Label}"/>
                                        </TextBlock>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Attachment tags strip (📎) — transient, cleared after each send -->
                    <ItemsControl ItemsSource="{Binding Attachments}" Margin="8,6,8,0">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasAttachments}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,4,4" CornerRadius="4" BorderThickness="1"
                                        Background="{Binding Background}" BorderBrush="{Binding BorderColor}">
                                    <DockPanel Margin="6,3" LastChildFill="True">
                                        <!-- × remove button -->
                                        <Button DockPanel.Dock="Right" Margin="4,0,0,0"
                                                Foreground="{Binding Foreground}"
                                                FocusVisualStyle="{x:Null}"
                                                Command="{Binding RemoveCommand}" Padding="2,0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="bd" Background="Transparent"
                                                            Padding="{TemplateBinding Padding}">
                                                        <TextBlock Text="×" FontSize="12"
                                                                   Foreground="{TemplateBinding Foreground}"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bd" Property="Background" Value="#40FFFFFF"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <!-- 📌 promote-to-pinned button — only when the chip has a real source path -->
                                        <Button DockPanel.Dock="Right" Margin="4,0,0,0"
                                                Foreground="{Binding Foreground}"
                                                FocusVisualStyle="{x:Null}"
                                                ToolTip="{Binding DataContext.TooltipPinChip, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                Visibility="{Binding CanPin, Converter={StaticResource b2v}}"
                                                Command="{Binding PinCommand}" Padding="2,0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="bd" Background="Transparent"
                                                            Padding="{TemplateBinding Padding}">
                                                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE718;" FontSize="11"
                                                                   Foreground="{TemplateBinding Foreground}"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bd" Property="Background" Value="#40FFFFFF"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <!-- tag label -->
                                        <TextBlock FontSize="10" VerticalAlignment="Center"
                                                   Foreground="{Binding Foreground}"
                                                   MaxWidth="160" TextTrimming="CharacterEllipsis">
                                            <Run FontFamily="Segoe MDL2 Assets" Text="&#xE723;  "/><Run Text="{Binding Label}"/>
                                        </TextBlock>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>

                <!-- Text input (row 2) -->
                <TextBox Grid.Row="2"
                         Text="{Binding Prompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         MinHeight="56" MaxHeight="150"
                         VerticalScrollBarVisibility="Auto"
                         BorderThickness="0" Background="Transparent"
                         Foreground="{Binding ThemeText}" CaretBrush="{Binding ThemeText}"
                         Padding="12,10,12,4" FontSize="13">
                    <TextBox.InputBindings>
                        <!-- Plain Enter → send; KeyBinding marks event Handled before AcceptsReturn runs.
                             Shift+Enter falls through to AcceptsReturn, inserts newline at cursor. -->
                        <KeyBinding Key="Return" Command="{Binding SendCommand}"/>
                        <!-- History nav: only fires when IsEnabled=true (single-line prompt).
                             When IsEnabled=false, CanExecute returns false → event propagates to TextBox → normal cursor movement. -->
                        <KeyBinding Key="Up"   Modifiers="Shift" Command="{Binding HistoryUpCommand}"/>
                        <KeyBinding Key="Down" Modifiers="Shift" Command="{Binding HistoryDownCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <!-- Toolbar row (row 3): attach buttons left, send button right -->
                <DockPanel Grid.Row="3" Margin="8,4,8,8" LastChildFill="False">

                    <!-- Send / Stop button (docked right) — dual purpose:
                         • Idle: "send" — purple (SendButtonColor: #7C4DFF connected / #555555 offline),
                           up-arrow icon.
                         • While IsLoading: "stop" — red (#C0392B), square icon.
                         The command is always SendCommand; SendAsync cancels the running request
                         when IsLoading (see InferpalToolWindowData.SendAsync), so the one button does both. -->
                    <Button DockPanel.Dock="Right" IsDefault="True"
                            Command="{Binding SendCommand}"
                            Width="34" Height="34" Padding="0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="ToolTip" Value="{Binding BtnSend}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                        <Setter Property="ToolTip" Value="{Binding BtnCancel}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="17" Background="{Binding SendButtonColor}" Width="34" Height="34">
                                    <TextBlock x:Name="icon" Text="↑" Foreground="White" FontSize="14" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <!-- Idle hover -->
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#6A3DE8"/>
                                    </Trigger>
                                    <!-- Stop state (running): red + square icon. Listed after the hover
                                         trigger so it overrides the idle hover colour while loading. -->
                                    <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                        <Setter TargetName="bd"   Property="Background" Value="#C0392B"/>
                                        <Setter TargetName="icon" Property="Text"       Value="■"/>
                                        <Setter TargetName="icon" Property="FontSize"   Value="13"/>
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Add context (＋) — single menu replacing the old row of four attach glyphs
                         (attach file / selection / browse / pin). Opens the labelled menu in row 0. -->
                    <Button DockPanel.Dock="Left" Width="28" Height="28" Margin="0,0,2,0"
                            ToolTip="{Binding MenuAddContext}"
                            Command="{Binding ToggleAttachMenuCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="4" Background="Transparent"
                                        BorderThickness="1" BorderBrush="Transparent"
                                        Width="28" Height="28">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE710;"
                                               FontSize="14" Foreground="{Binding ThemeSubtleText}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{Binding DataContext.ThemeHoverBg, ElementName=root}"/>
                                    </Trigger>
                                    <!-- Active state: attach menu open -->
                                    <DataTrigger Binding="{Binding IsAttachMenuOpen}" Value="True">
                                        <Setter TargetName="bd" Property="Background"  Value="{Binding DataContext.ThemeHoverBg, ElementName=root}"/>
                                        <Setter TargetName="bd" Property="BorderBrush" Value="#6A3DE8"/>
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Agent step-mode toggle — pause the agent after each tool call -->
                    <Button DockPanel.Dock="Left" Width="28" Height="28" Margin="0,0,2,0"
                            ToolTip="{Binding TooltipStepMode}"
                            Command="{Binding ToggleStepModeCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="4" Background="Transparent"
                                        Width="28" Height="28">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE769;"
                                               FontSize="13" Foreground="{Binding ThemeSubtleText}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{Binding DataContext.ThemeHoverBg, ElementName=root}"/>
                                    </Trigger>
                                    <!-- Active state: step mode ON -->
                                    <DataTrigger Binding="{Binding IsStepMode}" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#7C4DFF"/>
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Plan-mode toggle — read-only agent: explore and plan, no edits -->
                    <Button DockPanel.Dock="Left" Width="28" Height="28" Margin="0,0,2,0"
                            ToolTip="{Binding TooltipPlanMode}"
                            Command="{Binding TogglePlanModeCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="4" Background="Transparent"
                                        Width="28" Height="28">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE9D5;"
                                               FontSize="13" Foreground="{Binding ThemeSubtleText}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{Binding DataContext.ThemeHoverBg, ElementName=root}"/>
                                    </Trigger>
                                    <!-- Active state: plan mode ON -->
                                    <DataTrigger Binding="{Binding IsPlanMode}" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#7C4DFF"/>
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Chat/Agent switch — wired to AgentModeEnabled config (accent border = Agent mode).
                         Docked Right so it sits just left of the send button. -->
                    <Button DockPanel.Dock="Right" Height="22" Margin="2,0,6,0" Padding="8,1"
                            ToolTip="{Binding TooltipAgentMode}"
                            Command="{Binding ToggleAgentModeCommand}"
                            FocusVisualStyle="{x:Null}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="3" Background="Transparent"
                                        BorderThickness="1" BorderBrush="{Binding ThemeInputBorder}"
                                        Padding="{TemplateBinding Padding}">
                                    <TextBlock Text="{Binding AgentModeLabel}" FontSize="10" Foreground="{Binding ThemeText}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{Binding DataContext.ThemeHoverBg, ElementName=root}"/>
                                    </Trigger>
                                    <!-- Active state: Agent mode ON -->
                                    <DataTrigger Binding="{Binding IsAgentMode}" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{Binding DataContext.ThemeHoverBg, ElementName=root}"/>
                                        <Setter TargetName="bd" Property="BorderBrush" Value="#6A3DE8"/>
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </DockPanel>
            </Grid>
        </Border>

        <!-- ── Hint + Token info + Context budget bar ── -->
        <StackPanel Grid.Row="6">
            <DockPanel Margin="12,4,8,2" LastChildFill="True">
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding TokenInfo}"
                           Visibility="{Binding HasTokenInfo, Converter={StaticResource b2v}}"
                           Foreground="{Binding ThemeSubtleText}" FontSize="10" FontStyle="Italic"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding HintSend}"
                           Foreground="{Binding ThemeSubtleText}" FontSize="10"
                           VerticalAlignment="Center" />
            </DockPanel>
            <!-- Context-window fill bar — only visible when ContextWindowSize > 0 -->
            <ProgressBar Value="{Binding ContextFillPercent}"
                         Minimum="0" Maximum="100"
                         Height="3" Margin="12,0,8,4"
                         Foreground="{Binding ContextBudgetColor}"
                         BorderThickness="0"
                         Visibility="{Binding HasContextBudget, Converter={StaticResource b2v}}"
                         ToolTip="{Binding ContextBudgetTooltip}" />
        </StackPanel>
    </Grid>

</DataTemplate>
