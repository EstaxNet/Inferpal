                <TextBlock Text="turns" Foreground="{Binding TextForeground}"
                           VerticalAlignment="Center" Margin="6,0,0,0" FontSize="11" Opacity="0.65"/>
            </StackPanel>
        </Grid>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <CheckBox Content="{Binding LabelCompactionEnabled}"
                      IsChecked="{Binding CompactionEnabled, Mode=TwoWay}"
                      Foreground="{Binding TextForeground}"/>
            <TextBlock Text="ⓘ" Foreground="#569CD6" FontSize="10" VerticalAlignment="Center"
