                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding LabelCustomTools}" Foreground="{Binding TextForeground}"
                       FontSize="11" Opacity="0.75" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="ⓘ" Foreground="#569CD6" FontSize="10" VerticalAlignment="Center"
                       Margin="4,0,0,0" Cursor="Help" ToolTip="{Binding HintCustomTools}"/>
            <TextBlock Grid.Column="2" Text="{Binding ToolCountText}" Foreground="#569CD6"
                       FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0"/>
            <Button Grid.Column="4" Command="{Binding ToggleSectionToolRawCommand}" Cursor="Hand"
                    Content="{Binding ToolViewLabel}" Padding="8,2" FontSize="10">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="4" Background="{Binding SecondaryButtonBg}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{Binding SecondaryButtonFg}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{Binding SecondaryButtonHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- List view — hidden in Text view -->
        <StackPanel Visibility="{Binding ToolListViewVisible, Converter={StaticResource b2v}}">
        <Border Visibility="{Binding ToolEmpty, Converter={StaticResource b2v}}"
                BorderBrush="{Binding McpRowBorder}" BorderThickness="1" CornerRadius="6"
                Background="{Binding EditPanelBg}" Padding="14,16" Margin="0,0,0,8">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="{Binding ToolEmptyTitle}" Foreground="{Binding TextForeground}"
                           FontWeight="SemiBold" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding HintCustomTools}" Foreground="{Binding McpSubtleForeground}"
                           FontSize="11" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="300"/>
            </StackPanel>
        </Border>
        <ItemsControl ItemsSource="{Binding CustomToolRows}" Margin="0,0,0,6">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="{Binding DataContext.McpRowBackground, ElementName=root}" BorderBrush="{Binding DataContext.McpRowBorder, ElementName=root}" BorderThickness="1" CornerRadius="4" Padding="6,4" Margin="0,0,0,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" IsChecked="{Binding Enabled, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Label}" FontWeight="SemiBold" FontSize="12" FontFamily="Consolas" Foreground="{Binding DataContext.TextForeground, ElementName=root}" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Summary}" FontSize="10" Foreground="{Binding DataContext.McpSubtleForeground, ElementName=root}" FontFamily="Consolas" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <Button Grid.Column="2" Command="{Binding EditCommand}" ToolTip="{Binding DataContext.HintRowEdit, ElementName=root}" Width="26" Height="24" Margin="0,0,2,0">
                                <Button.Template><ControlTemplate TargetType="Button"><Border x:Name="bd" CornerRadius="3" Background="Transparent"><TextBlock Text="✎" FontSize="12" Foreground="{Binding DataContext.McpEditGlyph, ElementName=root}" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="{Binding DataContext.ThemeHoverBg, ElementName=root}"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                            </Button>
                            <Button Grid.Column="3" Command="{Binding DeleteCommand}" ToolTip="{Binding DataContext.HintRowDelete, ElementName=root}" Width="26" Height="24">
                                <Button.Template><ControlTemplate TargetType="Button"><Border x:Name="bd" CornerRadius="3" Background="Transparent"><TextBlock Text="🗑" FontSize="12" Foreground="#CC6666" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#5A2D2D"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                            </Button>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <Button Content="{Binding LabelToolAddTool}" Command="{Binding AddToolCommand}" HorizontalAlignment="Left" Padding="10,4" FontSize="11" Margin="0,0,0,6">
            <Button.Template><ControlTemplate TargetType="Button"><Border x:Name="bd" CornerRadius="4" Background="#0E639C" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextElement.Foreground="White"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#1177BB"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
        </Button>
        <Border Visibility="{Binding IsEditingTool, Converter={StaticResource b2v}}" Background="{Binding EditPanelBg}" BorderBrush="{Binding McpRowBorder}" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="{Binding ToolEditingTitle}" Foreground="{Binding TextForeground}" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6"/>
                <TextBlock Text="{Binding LabelToolName}" Foreground="{Binding TextForeground}" FontSize="10" Opacity="0.75"/>
                <TextBox Text="{Binding EditToolName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontSize="11" FontFamily="Consolas" Margin="0,2,0,6"/>
                <TextBlock Text="{Binding LabelToolCommand}" Foreground="{Binding TextForeground}" FontSize="10" Opacity="0.75"/>
                <TextBox Text="{Binding EditToolCommand, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="NoWrap" MinHeight="48" FontSize="11" FontFamily="Consolas" Margin="0,2,0,6" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                <TextBlock Text="{Binding EditToolError}" Foreground="#F48771" FontSize="10" TextWrapping="Wrap" Margin="0,0,0,6"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="{Binding BtnMcpSaveServer}" Command="{Binding SaveToolCommand}" Padding="10,4" FontSize="11" Margin="0,0,6,0">
                        <Button.Template><ControlTemplate TargetType="Button"><Border x:Name="bd" CornerRadius="4" Background="#1B6B35" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextElement.Foreground="White"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#28A047"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                    </Button>
                    <Button Content="{Binding BtnMcpCancelServer}" Command="{Binding CancelEditToolCommand}" Padding="10,4" FontSize="11">
                        <Button.Template><ControlTemplate TargetType="Button"><Border x:Name="bd" CornerRadius="4" Background="{Binding SecondaryButtonBg}" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextElement.Foreground="{Binding SecondaryButtonFg}"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="{Binding SecondaryButtonHover}"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>
        </StackPanel>
        <!-- end tools list view -->

        <!-- Text view (raw editor) — the other face of the header toggle -->
        <StackPanel Visibility="{Binding SectionToolRawExpanded, Converter={StaticResource b2v}}" Margin="0,0,0,20">
            <TextBox Text="{Binding CustomTools, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="NoWrap" MinHeight="60" FontFamily="Consolas" FontSize="11" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Margin="0,0,0,6"/>
            <Button Content="{Binding BtnRowImport}" Command="{Binding ImportToolCommand}" HorizontalAlignment="Left" Padding="10,4" FontSize="11">
                <Button.Template><ControlTemplate TargetType="Button"><Border x:Name="bd" CornerRadius="4" Background="{Binding SecondaryButtonBg}" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextElement.Foreground="{Binding SecondaryButtonFg}"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="{Binding SecondaryButtonHover}"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
            </Button>
        </StackPanel>

        </StackPanel>
        <!-- end TAB: Tools (Commands & tools) -->

        <!-- ══ Save bar (always visible) ═══════════════════════════════════ -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
            <Button Content="{Binding BtnSave}"
                    Command="{Binding SaveCommand}"
                    Padding="16,6"/>
            <TextBlock Text="{Binding SaveStatus}"
                       Foreground="{Binding TextForeground}"
                       VerticalAlignment="Center"
                       FontSize="12" Margin="10,0,0,0"/>
        </StackPanel>

    </StackPanel>
    </ScrollViewer>

</DataTemplate>
